# =============================================================================
# Exocórtex.IA — Dockerfile para Dry-Run do Setup
# =============================================================================
# Propósito: validar o setup.sh em ambiente limpo e isolado.
# Documenta dependências de SO, pacotes e software necessário.
#
# Uso:
#   docker build -t exocortex-rc-test -f Dockerfile.test .
#   docker run --rm exocortex-rc-test
# =============================================================================

FROM ubuntu:24.04

LABEL maintainer="exocortex" \
      description="Dry-run environment for Exocórtex setup.sh validation"

# ─── Dependências de SO ────────────────────────────────────────────────────
# Pacotes necessários para o setup.sh funcionar:
#   bash      — shell (já incluído)
#   git       — DocBrain clone, acervo versioning
#   curl      — downloads, health checks
#   rsync     — acervo copy (preferido sobre cp -r)
#   python3   — harness tools, Drive patch
#   nodejs    — DocBrain build, nlm CLI, context7 MCP
#   npm       — DocBrain dependencies
#
# NÃO necessários para dry-run básico:
#   docker    — Hindsight (nested Docker não é testável aqui)
#   uv        — nlm CLI (testável mas não obrigatório)
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    git \
    curl \
    rsync \
    python3 \
    python3-pip \
    nodejs \
    npm \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ─── Criar usuário não-root ────────────────────────────────────────────────
RUN useradd -m -s /bin/bash testuser
USER testuser
WORKDIR /home/testuser

# ─── Simular HERMES_HOME e hermes CLI stub ─────────────────────────────────
# O setup.sh verifica `command -v hermes` — criamos um stub que responde
# aos comandos mínimos para que os checks passem sem o Hermes real.
RUN mkdir -p /home/testuser/.hermes/skills/exocortex \
             /home/testuser/.hermes/profiles \
             /home/testuser/.hermes/skill-bundles \
             /home/testuser/.hermes/reminders \
             /home/testuser/bin

# Stub do hermes CLI
RUN cat > /home/testuser/bin/hermes <<'STUB'
#!/usr/bin/env bash
case "$1" in
  --version) echo "hermes-stub 0.0.0 (dry-run)" ;;
  mcp)
    case "$2" in
      list) echo "" ;;  # nenhum MCP instalado
      add)  echo "stub: mcp add $3 (simulated)" ;;
      remove) echo "stub: mcp remove $3 (simulated)" ;;
    esac ;;
  skill)
    case "$2" in
      list) echo "" ;;
    esac ;;
  profile)
    case "$2" in
      create) echo "stub: profile create $3 (simulated)" ;;
    esac ;;
  *) echo "hermes-stub: unknown command $*" ;;
esac
STUB
RUN chmod +x /home/testuser/bin/hermes

ENV PATH="/home/testuser/bin:$PATH"
ENV HERMES_HOME="/home/testuser/.hermes"
ENV EXOCORTEX_HOME="/home/testuser/exocortex"

# ─── Copiar artifacts do instalador ────────────────────────────────────────
COPY --chown=testuser:testuser plans/pdd_v2/artifacts/ /home/testuser/installer/

# ─── Executar setup.sh ─────────────────────────────────────────────────────
# Variáveis de controle:
#   EXOCORTEX_ENABLE_HINDSIGHT=0 — não tentar Docker dentro de Docker
#   EXOCORTEX_DOCBRAIN_DIR=/tmp/docbrain-test — não clonar repo real
CMD ["bash", "-c", "\
  echo '=== Exocórtex RC Dry-Run ===' && \
  echo '' && \
  echo 'OS:      '$(cat /etc/os-release | grep PRETTY_NAME | cut -d= -f2) && \
  echo 'Bash:    '$(bash --version | head -1) && \
  echo 'Git:     '$(git --version) && \
  echo 'Python:  '$(python3 --version) && \
  echo 'Node:    '$(node --version) && \
  echo 'npm:     '$(npm --version) && \
  echo 'rsync:   '$(rsync --version | head -1) && \
  echo 'hermes:  '$(hermes --version) && \
  echo '' && \
  cd /home/testuser/installer && \
  HERMES_HOME=/home/testuser/.hermes \
  EXOCORTEX_HOME=/home/testuser/exocortex \
  EXOCORTEX_ENABLE_HINDSIGHT=0 \
  EXOCORTEX_DOCBRAIN_DIR=/tmp/docbrain-skip \
  bash setup.sh \
"]
