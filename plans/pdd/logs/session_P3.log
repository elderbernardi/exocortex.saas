cp .agent/skills/browser-use/SKILL.md ~/.hermes/skills/exocortex/browser-use/SKILL.md
cp .agent/skills/browser-use/scripts/browser-use.sh ~/.hermes/skills/exocortex/browser-use/scripts/browser-use.sh

# 3. Instalar dependência CLI do DuckDuckGo
pip install ddgs
# Resultado: ddgs v9.14.4

# 4. browser-use CLI já estava instalado (~/.local/share/mise/shims/browser-use)
```

