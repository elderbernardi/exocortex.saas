# Personal microversos (generated per-user by onboarding)
acervo/micro/gabinete/
acervo/micro/ensino/

# Client-specific microversos (sensitive brand assets)
acervo/micro/sales-ai/

# Marketing / promotion HTML overviews
_design/*.html

# Debug/runtime artifacts
nohup.out


# AcervoIndex runtime manifest (mutable state, not seed)
# Keep the dir tracked (.gitkeep/README.md); ignore only the mutable manifests
acervo/global/tools/state/*.json
# Derived catalog (Plane 2, rebuildable via `acervoctl reindex`)
acervo/global/tools/state/catalog.sqlite*
# Retrieval journal (Plane 2 observability, H12 use-decay substrate — append-only, disposable)
acervo/global/tools/state/*.jsonl
