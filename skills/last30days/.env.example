# last30days-skill — optional API keys
# Copy to ~/.config/last30days/.env and fill in your keys
# All keys are OPTIONAL — the skill works with 5 free sources without any keys

# ─── Reasoning Provider (pick one) ────────────────────────────────────────
# DeepSeek V4 Flash (recommended for Exocórtex)
DEEPSEEK_API_KEY=sk-...

# Gemini (free tier, Google AI Studio)
# GOOGLE_API_KEY=...

# OpenRouter (multi-model gateway)
# OPENROUTER_API_KEY=sk-or-v1-...

# xAI (Grok)
# XAI_API_KEY=xai-...

# ─── Custom Provider Overrides (for DeepSeek) ─────────────────────────────
# These redirect the OpenRouter client to DeepSeek's compatible API
LAST30DAYS_REASONING_PROVIDER=openrouter
LAST30DAYS_OPENROUTER_BASE_URL=https://api.deepseek.com/v1/chat/completions
LAST30DAYS_OPENROUTER_MODEL=deepseek-v4-flash
LAST30DAYS_PLANNER_MODEL=deepseek-v4-flash
LAST30DAYS_RERANK_MODEL=deepseek-v4-flash

# ─── Social Media Sources ─────────────────────────────────────────────────
# X/Twitter (use DEEPSEEK_API_KEY or XAI_API_KEY above, or browser cookies)
# FROM_BROWSER=firefox

# ScrapeCreators (free 100 credits at scrapecreators.com)
# SCRAPECREATORS_API_KEY=sc-...
# INCLUDE_SOURCES=tiktok,instagram,threads,pinterest

# Bluesky (app password at bsky.app/settings/app-passwords)
# BSKY_HANDLE=your-handle.bsky.social
# BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# TruthSocial
# TRUTHSOCIAL_TOKEN=...

# ─── Web Search ───────────────────────────────────────────────────────────
# Brave Search (free tier at brave.com/search/api)
# BRAVE_API_KEY=BSA...

# Exa, Serper, Parallel (alternatives)
# EXA_API_KEY=...
# SERPER_API_KEY=...
# PARALLEL_API_KEY=...

# ─── Deep Research ────────────────────────────────────────────────────────
# Perplexity via OpenRouter (~$0.90/query)
# OPENROUTER_API_KEY=sk-or-v1-...

# ─── Output ───────────────────────────────────────────────────────────────
# LAST30DAYS_MEMORY_DIR=~/Documents/Last30Days/
