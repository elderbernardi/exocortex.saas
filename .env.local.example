# =============================================================================
# Exocórtex.IA — Configuração Local (.env.local)
# =============================================================================
# Este arquivo é gerado pelo setup interativo e NÃO deve ser commitado.
# Copie este arquivo para .env.local e edite os valores:
#   cp .env.local.example .env.local
#
# Valores aqui são carregados automaticamente pelo setup.sh.
# Variáveis de ambiente definidas no shell têm prioridade sobre este arquivo.
# =============================================================================

# ─── Paths ──────────────────────────────────────────────────────────────────

# Diretório do runtime Hermes. Default: ~/.hermes
# HERMES_HOME="$HOME/.hermes"

# Diretório do workspace cognitivo Exocórtex. Default: ~/exocortex
# EXOCORTEX_HOME="$HOME/exocortex"

# ─── API Keys ──────────────────────────────────────────────────────────────

# Chave OpenRouter — usada pelo DocBrain, LLM routing e Hindsight.
# LLM routing / providers remotos
# OPENROUTER_API_KEY="sk-or-v1-..."
# DEEPSEEK_API_KEY="sk-..."
# Observação: OPENROUTER_API_KEY e DEEPSEEK_API_KEY são credenciais distintas.
# Alguns fluxos aceitam OpenRouter ou DeepSeek direto; outros ainda exigem o nome literal da env var.

# Token do Telegram Bot — gateway principal para interação.
# Obtenha via @BotFather no Telegram.
# TELEGRAM_BOT_TOKEN=""

# Chave DeepSeek — fallback para Hindsight quando OpenRouter não disponível.
# DEEPSEEK_API_KEY=""

# Chave Context7 — documentação atualizada de tech stacks (opcional).
# Obtenha em: https://context7.com
# CONTEXT7_API_KEY=""

# Firecrawl (opcional)
# FIRECRAWL_API_KEY="fc-..."
# FIRECRAWL_BASE_URL="http://127.0.0.1:3002"

# Override de LLM key para DocBrain (sobrescreve OPENROUTER_API_KEY).
# DOCBRAIN_LLM_API_KEY=""

# Chave Hindsight cloud (opcional, para uso do serviço cloud).
# HINDSIGHT_API_KEY=""

# ─── Features ──────────────────────────────────────────────────────────────

# Ativar Hindsight (memória operacional via Docker local). Default: 1
# EXOCORTEX_ENABLE_HINDSIGHT="1"

# Ativar Hermes WebUI (cockpit web opcional). Default: 0
# EXOCORTEX_ENABLE_HERMES_WEBUI="0"

# ─── Hermes WebUI (quando ativado) ─────────────────────────────────────────

# Diretório de instalação do WebUI. Default: $HERMES_HOME/hermes-webui
# EXOCORTEX_HERMES_WEBUI_HOME=""

# Porta do servidor WebUI. Default: 8787
# EXOCORTEX_HERMES_WEBUI_PORT="8787"

# Bind address do WebUI. Default: 127.0.0.1
# EXOCORTEX_HERMES_WEBUI_HOST="127.0.0.1"

# ─── DocBrain ──────────────────────────────────────────────────────────────

# Diretório de instalação do DocBrain. Default: $EXOCORTEX_HOME/tools/docbrain
# EXOCORTEX_DOCBRAIN_DIR=""

# ─── Google Credentials ──────────────────────────────────────────────────

# Path para service account JSON (alternativa a gcloud ADC).
# GOOGLE_APPLICATION_CREDENTIALS=""
