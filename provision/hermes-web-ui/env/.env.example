# =============================================================================
# Hermes Web UI — Exocórtex Provisioning
# =============================================================================

EXOCORTEX_HERMES_WEB_UI_REPO_URL=https://github.com/EKKOLearnAI/hermes-web-ui.git
# Pin explícito do upstream validado pelo Exocórtex em 2026-06-12 (release v0.6.14).
EXOCORTEX_HERMES_WEB_UI_REF=v0.6.14
# Override consciente para refs flutuantes (main/master/HEAD) somente em dev.
EXOCORTEX_ALLOW_FLOATING_UPSTREAM_REF=0
EXOCORTEX_HERMES_WEB_UI_IMAGE=exocortex-hermes-web-ui:local
EXOCORTEX_HERMES_WEB_UI_CONTAINER_NAME=exocortex-hermes-web-ui
EXOCORTEX_HERMES_WEB_UI_SERVICE=hermes-web-ui

EXOCORTEX_HERMES_HOME=$HOME/.hermes
EXOCORTEX_HOME=$HOME/exocortex
EXOCORTEX_WEB_UI_HOME=$HOME/.hermes-web-ui

EXOCORTEX_UI_PORT=8648
EXOCORTEX_UI_BIND_IP=127.0.0.1
EXOCORTEX_UI_CONTAINER_PORT=8648
EXOCORTEX_UI_PREVIEW_PORT=8651
EXOCORTEX_UI_XAI_OAUTH_PORT=56121

EXOCORTEX_BOOTSTRAP_RUNTIME=1
EXOCORTEX_BOOTSTRAP_FORCE=0
EXOCORTEX_SETUP_FLAGS=

EXOCORTEX_ALLOWED_PROFILES=default,manut
EXOCORTEX_DEFAULT_PROFILE=default
EXOCORTEX_GATEWAY_AUTOSTART_ENABLED=1

EXOCORTEX_ADMIN_USERNAME=admin
EXOCORTEX_ADMIN_PASSWORD=__GENERATE_ME__
AUTH_JWT_SECRET=__GENERATE_ME__

LOG_LEVEL=info
BRIDGE_LOG_LEVEL=info
WORKSPACE_BASE=$HOME
# Obrigatório quando EXOCORTEX_UI_BIND_IP não for loopback.
CORS_ORIGINS=

# Chaves opcionais propagadas para o runtime Hermes/Web UI.
OPENROUTER_API_KEY=
FIRECRAWL_API_KEY=
