ARG BASE_IMAGE=nousresearch/hermes-agent:latest
FROM ${BASE_IMAGE}

ARG NODE_VERSION=24.15.0
ARG HERMES_WEB_UI_REPO_URL=https://github.com/EKKOLearnAI/hermes-web-ui.git
ARG HERMES_WEB_UI_REF=main

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    make \
    g++ \
    python3 \
    rsync \
    && rm -rf /var/lib/apt/lists/*

RUN ARCH=$(dpkg --print-architecture) \
    && if [ "$ARCH" = "amd64" ]; then NODE_ARCH="x64"; else NODE_ARCH="$ARCH"; fi \
    && curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.gz" -o /tmp/node.tar.gz \
    && rm -rf /usr/local/lib/node_modules/npm /usr/local/lib/node_modules/corepack \
       /usr/local/bin/node /usr/local/bin/npm /usr/local/bin/npx /usr/local/bin/corepack \
    && tar -xzf /tmp/node.tar.gz -C /usr/local --strip-components=1 \
    && rm -f /tmp/node.tar.gz \
    && node --version \
    && npm --version

WORKDIR /opt
RUN git clone "$HERMES_WEB_UI_REPO_URL" hermes-web-ui-src \
    && cd hermes-web-ui-src \
    && git checkout "$HERMES_WEB_UI_REF"

WORKDIR /opt/hermes-web-ui-src
COPY . /opt/exocortex.saas
ENV NODE_OPTIONS=--max-old-space-size=4096
RUN npm ci --ignore-scripts \
    && npm rebuild node-pty \
    && npm run build \
    && npm prune --omit=dev

RUN mkdir -p /srv/hermes /srv/hermes-web-ui /srv/exocortex

ENV NODE_ENV=production
ENV HOME=/root
ENV HERMES_HOME=/srv/hermes
ENV HERMES_WEB_UI_HOME=/srv/hermes-web-ui
ENV HERMES_WEB_UI_MANAGED_GATEWAY=1
ENV HERMES_BIN=/opt/hermes/.venv/bin/hermes
ENV PATH=/opt/hermes/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ENV PORT=8648
ENV BIND_HOST=0.0.0.0
ENV WORKSPACE_BASE=/srv

EXPOSE 8648 8651 56121

USER root
WORKDIR /opt/hermes-web-ui-src
ENTRYPOINT ["node", "dist/server/index.js"]
CMD []
