{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Exocortex Dogfood Result",
  "type": "object",
  "required": ["feature_id", "status", "risk", "summary", "criteria", "artifacts", "blocked_reason"],
  "properties": {
    "feature_id": { "type": "string", "pattern": "^EX-[0-9]{2}$" },
    "status": { "type": "string", "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED"] },
    "risk": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
    "summary": { "type": "string", "minLength": 1 },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "met", "evidence"],
        "properties": {
          "criterion": { "type": "string", "minLength": 1 },
          "met": { "type": "boolean" },
          "evidence": { "type": "string" }
        }
      }
    },
    "artifacts": { "type": "object" },
    "blocked_reason": { "type": ["string", "null"] }
  }
}
